# Copy to apps/desktop/.env and services/api/.env

# --- Desktop (apps/desktop/.env) ---
VITE_API_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=

# --- API (services/api/.env) ---
OPENROUTER_API_KEY=
CLAUDE_MODEL=anthropic/claude-sonnet-4

# --- SUPABASE KEYS ---
SUPABASE_URL=
SUPABASE_KEY=

# --- CLERK KEYS ---
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

APP_ENV=development
ALLOW_DEV_TOKENS=true

# --- REDIS URL ---
REDIS_URL=redis://localhost:6379

BRAVE_SEARCH_API_KEY=
E2B_API_KEY=

# --- LANGSMITH ---
LANGSMITH_API_KEY=

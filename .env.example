# --- STRIPE ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PORTAL_URL=
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:1420/settings

AGENT_TASK_TTL_SECONDS=86400
AUDIT_LOG_ENABLED=true
CORS_ORIGINS=http://localhost:1420,tauri://localhost
